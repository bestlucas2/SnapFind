# Copy to .env and adjust as needed.

# --- Security ---
# Generate a strong value, e.g. python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# --- Database ---
# Default: zero-config local SQLite file (nothing to install or run).
DATABASE_URL=sqlite:///./snapfind.db
# Full multi-user deployment with PostgreSQL (docker-compose.yml provisions it):
# DATABASE_URL=postgresql+psycopg://snapfind:snapfind@localhost:5432/snapfind

# --- Storage ---
# Local object store. Files are namespaced per-user underneath this directory.
STORAGE_DIR=uploads
MAX_UPLOAD_MB=25

# --- OCR ---
# Number of background worker threads for OCR processing.
OCR_WORKERS=3
# Optional: absolute path to the tesseract binary if it is not on PATH.
# Windows example: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=

# --- App ---
APP_NAME=SnapFind
DEBUG=true
